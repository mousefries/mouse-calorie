<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Mouse OS ✨</title>
    <style>
        /* 全局桌面背景与字体 */
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            font-family: 'PingFang SC', sans-serif;
            background: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop') center/cover no-repeat; /* 高级抽象背景 */
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            -webkit-user-select: none;
        }

        /* 顶部状态栏 */
        .status-bar {
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            color: white;
            font-size: 14px;
            font-weight: bold;
            text-shadow: 0 1px 3px rgba(0,0,0,0.5);
            z-index: 10;
        }

        /* 桌面图标网格 */
        .desktop-grid {
            flex: 1;
            padding: 30px;
            display: flex;
            align-content: flex-start;
            gap: 30px;
            flex-wrap: wrap;
        }

        .app-icon {
            width: 70px;
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .app-icon:active { transform: scale(0.9); }
        
        .icon-box {
            width: 60px;
            height: 60px;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            border-radius: 18px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 32px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.4);
            margin-bottom: 8px;
        }
        .icon-text {
            color: white;
            font-size: 12px;
            font-weight: 500;
            text-shadow: 0 1px 4px rgba(0,0,0,0.6);
        }

        /* 底部 Dock 栏 */
        .dock-container {
            padding-bottom: 20px;
            display: flex;
            justify-content: center;
            z-index: 10;
        }
        .dock {
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: 12px 20px;
            border-radius: 30px;
            display: flex;
            gap: 20px;
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        /* 🚀 App 运行窗口 (核心魔法) */
        .window-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(5px);
            z-index: 100;
            display: none; /* 默认隐藏 */
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .window-frame {
            width: 90%;
            max-width: 500px;
            height: 85%;
            background: #f7f9fc;
            border-radius: 25px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            transform: translateY(20px) scale(0.95);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        
        /* 窗口顶部控制条 */
        .window-header {
            height: 40px;
            background: rgba(255,255,255,0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            border-bottom: 1px solid #ddd;
        }
        .window-title { font-size: 14px; font-weight: bold; color: #333; }
        .close-btn {
            position: absolute;
            right: 15px;
            width: 24px;
            height: 24px;
            background: #e5e5ea;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 12px;
            font-weight: bold;
            color: #888;
            cursor: pointer;
            border: none;
        }
        .close-btn:active { background: #d1d1d6; }
        
        /* 内部网页容器 */
        iframe {
            flex: 1;
            width: 100%;
            border: none;
            background: white;
        }
    </style>
</head>
<body>

    <div class="status-bar">
        <div id="clock">00:00</div>
        <div>100% 🔋</div>
    </div>

    <div class="desktop-grid">
        </div>

    <div class="dock-container">
        <div class="dock">
            <div class="app-icon" onclick="openApp('nutrition.html', 'AI 营养师')">
                <div class="icon-box" style="background: linear-gradient(135deg, #ff9a9e, #fecfef);">🥗</div>
            </div>
            
            <div class="app-icon" onclick="openApp('game.html', '领地战 Color Wars')">
                <div class="icon-box" style="background: linear-gradient(135deg, #a18cd1, #fbc2eb);">🕹️</div>
            </div>
            
            <div class="app-icon" onclick="alert('开发中喵！')">
                <div class="icon-box" style="background: linear-gradient(135deg, #84fab0, #8fd3f4);">🎵</div>
            </div>
        </div>
    </div>

    <div class="window-overlay" id="appOverlay">
        <div class="window-frame" id="appFrame">
            <div class="window-header">
                <div class="window-title" id="appTitle">App Name</div>
                <button class="close-btn" onclick="closeApp()">✖</button>
            </div>
            <iframe id="appContent" src=""></iframe>
        </div>
    </div>

    <script>
        // 实时时钟
        function updateClock() {
            const now = new Date();
            const timeStr = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
            document.getElementById('clock').innerText = timeStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // 打开 App 魔法
        function openApp(url, title) {
            const overlay = document.getElementById('appOverlay');
            const frame = document.getElementById('appFrame');
            
            document.getElementById('appTitle').innerText = title;
            document.getElementById('appContent').src = url; // 加载对应的 HTML
            
            overlay.style.display = 'flex';
            // 延迟一点点加上透明度和缩放效果，触发 CSS 动画
            setTimeout(() => {
                overlay.style.opacity = '1';
                frame.style.transform = 'translateY(0) scale(1)';
            }, 10);
        }

        // 关闭 App
        function closeApp() {
            const overlay = document.getElementById('appOverlay');
            const frame = document.getElementById('appFrame');
            
            overlay.style.opacity = '0';
            frame.style.transform = 'translateY(20px) scale(0.95)';
            
            setTimeout(() => {
                overlay.style.display = 'none';
                document.getElementById('appContent').src = ''; // 清空内存
            }, 300); // 等待动画结束
        }
    </script>
</body>
</html>
