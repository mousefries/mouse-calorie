<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>Mouse OS ✨</title>
    <style>
        /* 🍎 纯代码打造的极光暗色背景，永不丢失，高保真对比度 */
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
            background: linear-gradient(135deg, #111122 0%, #221133 50%, #331122 100%);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            box-sizing: border-box;
            -webkit-user-select: none;
        }

        /* 顶部苹果风状态栏 */
        .status-bar {
            padding: 12px 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            font-size: 14px;
            font-weight: 600;
            z-index: 10;
            background: rgba(0, 0, 0, 0.1);
        }
        .status-left { display: flex; align-items: center; gap: 6px; }
        .live-dot { width: 8px; height: 8px; background: #34C759; border-radius: 50%; animation: blink 2s infinite; }
        @keyframes blink { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }

        /* 🖥️ 核心改进：大网格桌面（确保一定有内容显示！） */
        .desktop-grid {
            flex: 1;
            padding: 40px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            grid-auto-rows: 100px;
            gap: 35px;
            align-content: flex-start;
            z-index: 5;
        }

        /* 拟物化 App 图标 */
        .app-icon {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .app-icon:active { transform: scale(0.88); }
        
        .icon-box {
            width: 65px;
            height: 65px;
            border-radius: 18px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 34px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.15);
            transition: 0.3s;
        }
        .icon-text {
            color: rgba(255, 255, 255, 0.9);
            font-size: 13px;
            font-weight: 600;
            margin-top: 10px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.8);
            white-space: nowrap;
        }

        /* 底部智能 Dock 栏 */
        .dock-container {
            padding-bottom: 25px;
            display: flex;
            justify-content: center;
            z-index: 10;
            width: 100%;
        }
        .dock {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            padding: 12px 25px;
            border-radius: 32px;
            display: flex;
            gap: 25px;
            border: 1px solid rgba(255,255,255,0.12);
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        }
        .dock .app-icon .icon-text { display: none; } /* Dock 栏隐藏文字更像苹果 */
        .dock .icon-box { width: 55px; height: 55px; font-size: 28px; }

        /* 🚀 全屏弹窗系统 (毛玻璃材质) */
        .window-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 100;
            display: none;
            justify-content: center;
            align-items: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        .window-frame {
            width: 92%;
            max-width: 480px;
            height: 85vh;
            background: #1c1c38;
            border-radius: 28px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 25px 60px rgba(0,0,0,0.6);
            border: 1px solid rgba(255,255,255,0.1);
            transform: translateY(30px) scale(0.95);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        
        /* 窗口顶部安全控制条 */
        .window-header {
            height: 45px;
            background: rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .window-title { font-size: 15px; font-weight: 600; color: white; }
        .close-btn {
            position: absolute;
            right: 15px;
            width: 26px;
            height: 26px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 12px;
            font-weight: bold;
            color: #ccc;
            cursor: pointer;
            border: none;
            transition: 0.2s;
        }
        .close-btn:hover { background: #ff3b30; color: white; }
        
        iframe {
            flex: 1;
            width: 100%;
            border: none;
            background: transparent;
        }
    </style>
</head>
<body>

    <div class="status-bar">
        <div class="status-left">
            <div class="live-dot"></div>
            <div id="clock">00:00</div>
        </div>
        <div>iPad 🔋 100%</div>
    </div>

    <div class="desktop-grid">
        <div class="app-icon" onclick="openApp('nutrition.html', 'AI 营养师')">
            <div class="icon-box" style="background: linear-gradient(135deg, #ff9a9e, #fecfef);"> Salad 🥗</div>
            <div class="icon-text">AI 营养师</div>
        </div>
        
        <div class="app-icon" onclick="openApp('game.html', '领地战 Color Wars')">
            <div class="icon-box" style="background: linear-gradient(135deg, #a18cd1, #fbc2eb);"> Game 🕹️</div>
            <div class="icon-text">领地战</div>
        </div>
    </div>

    <div class="dock-container">
        <div class="dock">
            <div class="app-icon" onclick="openApp('nutrition.html', 'AI 营养师')">
                <div class="icon-box" style="background: linear-gradient(135deg, #ff9a9e, #fecfef);">🥗</div>
            </div>
            <div class="app-icon" onclick="openApp('game.html', '领地战 Color Wars')">
                <div class="icon-box" style="background: linear-gradient(135deg, #a18cd1, #fbc2eb);">🕹️</div>
            </div>
            <div class="app-icon" onclick="alert('秘密开发中喵~ 🎵')">
                <div class="icon-box" style="background: linear-gradient(135deg, #84fab0, #8fd3f4);">🎵</div>
            </div>
        </div>
    </div>

    <div class="window-overlay" id="appOverlay">
        <div class="window-frame" id="appFrame">
            <div class="window-header">
                <div class="window-title" id="appTitle">App</div>
                <button class="close-btn" onclick="closeApp()">✖</button>
            </div>
            <iframe id="appContent" src=""></iframe>
        </div>
    </div>

    <script>
        // 苹果原生时钟更新
        function updateClock() {
            const now = new Date();
            const timeStr = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
            document.getElementById('clock').innerText = timeStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // 丝滑开启 App 动效
        function openApp(url, title) {
            const overlay = document.getElementById('appOverlay');
            const frame = document.getElementById('appFrame');
            
            document.getElementById('appTitle').innerText = title;
            document.getElementById('appContent').src = url; 
            
            overlay.style.display = 'flex';
            setTimeout(() => {
                overlay.style.opacity = '1';
                frame.style.transform = 'translateY(0) scale(1)';
            }, 20);
        }

        // 关闭 App 动效
        function closeApp() {
            const overlay = document.getElementById('appOverlay');
            const frame = document.getElementById('appFrame');
            
            overlay.style.opacity = '0';
            frame.style.transform = 'translateY(30px) scale(0.95)';
            
            setTimeout(() => {
                overlay.style.display = 'none';
                document.getElementById('appContent').src = ''; 
            }, 300);
        }
    </script>
</body>
</html>
